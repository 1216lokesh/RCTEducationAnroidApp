<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="@string/followup1week_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="@string/followup1week_subtitle"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="32dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="@string/followup1week_q1"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <RadioGroup android:id="@+id/rg1"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <RadioButton android:text="@string/followup1week_q1_a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <RadioButton android:text="@string/followup1week_q1_b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <RadioButton android:text="@string/followup1week_q1_c"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </RadioGroup>

        <TextView
            android:text="@string/followup1week_q2"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <RadioGroup android:id="@+id/rg2"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <RadioButton android:text="@string/followup1week_q2_a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <RadioButton android:text="@string/followup1week_q2_b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <RadioButton android:text="@string/followup1week_q2_c"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </RadioGroup>

        <TextView
            android:text="@string/followup1week_q3"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <RadioGroup android:id="@+id/rg3"
            android:layout_marginBottom="32dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <RadioButton android:text="@string/followup1week_q3_a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <RadioButton android:text="@string/followup1week_q3_b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <RadioButton android:text="@string/followup1week_q3_c"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </RadioGroup>

        <Button
            android:id="@+id/btnSubmit"
            android:text="@string/submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#2E7D32"/>

    </LinearLayout>
</ScrollView>