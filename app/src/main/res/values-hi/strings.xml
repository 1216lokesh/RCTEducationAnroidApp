    <string name="quiz1_q3_a">दाँत सफेद करने के लिए</string>
    <string name="quiz1_q3_b">दाँत की सड़न हटाने के लिए</string>
    <string name="quiz1_q3_c">संक्रमित गूदे का इलाज करने के लिए</string>
    <string name="quiz2_title">प्रश्नोत्तरी - अपॉइंटमेंट 2</string>
    <string name="quiz2_q1">1. कैनाल भरने के लिए किस सामग्री का उपयोग किया जाता है?</string>
    <string name="quiz2_q1_a">सीमेंट</string>
    <string name="quiz2_q1_b">गट्टा-पर्चा</string>
    <string name="quiz2_q1_c">रुई</string>
    <string name="quiz2_q2">2. क्षेत्र को सुन्न करने के लिए क्या उपयोग किया जाता है?</string>
    <string name="quiz2_q2_a">लोकल एनेस्थीसिया</string>
    <string name="quiz2_q2_b">बर्फ की थैली</string>
    <string name="quiz2_q2_c">दर्द निवारक</string>
    <string name="quiz2_q3">3. रूट कैनाल प्रक्रिया में क्या हटाया जाता है?</string>
    <string name="quiz2_q3_a">पूरा दाँत</string>
    <string name="quiz2_q3_b">संक्रमित गूदा</string>
    <string name="quiz2_q3_c">दाँत की परत</string>
    <string name="quiz3_title">प्रश्नोत्तरी - अपॉइंटमेंट 3</string>
    <string name="quiz3_q1">1. रूट कैनाल के बाद कितनी बार ब्रश करना चाहिए?</string>
    <string name="quiz3_q1_a">दिन में दो बार</string>
    <string name="quiz3_q1_b">सप्ताह में एक बार</string>
    <string name="quiz3_q1_c">महीने में एक बार</string>
    <string name="quiz3_q2">2. रूट कैनाल के बाद कौन से खाद्य पदार्थ से बचें?</string>
    <string name="quiz3_q2_a">नरम खाद्य पदार्थ</string>
    <string name="quiz3_q2_b">कठोर और चिपचिपे खाद्य पदार्थ</string>
    <string name="quiz3_q2_c">फल</string>
    <string name="quiz3_q3">3. दंत चिकित्सक से कब संपर्क करें?</string>
    <string name="quiz3_q3_a">दर्द या सूजन होने पर</string>
