    <string name="apt4_q1_c">अभी भी दर्द है</string>
    <string name="apt4_q2">2. क्या आप उपचारित दाँत को नियमित रूप से ब्रश कर रहे हैं?</string>
    <string name="apt4_q2_a">हाँ</string>
    <string name="apt4_q2_b">नहीं</string>
    <string name="apt4_q2_c">कभी-कभी</string>
    <string name="apt4_q3">3. क्या इस ऐप की शिक्षा से मदद मिली?</string>
    <string name="apt4_q3_a">हाँ, बहुत मदद मिली</string>
