    <string name="apt3_q1_c">दर्द हो रहा था</string>
    <string name="apt3_q2">2. क्या आपने पोस्ट-ऑप निर्देशों का पालन किया?</string>
    <string name="apt3_q2_a">हाँ</string>
    <string name="apt3_q2_b">नहीं</string>
    <string name="apt3_q2_c">आंशिक रूप से</string>
    <string name="apt3_q3">3. क्या आप आज क्राउन के लिए तैयार हैं?</string>
