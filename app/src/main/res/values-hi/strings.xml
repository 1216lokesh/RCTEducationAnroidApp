    <string name="apt3_baseline_title">अपॉइंटमेंट 3 - आधार रेखा</string>
    <string name="apt3_q1">1. रूट कैनाल के बाद दाँत कैसा लग रहा है?</string>
    <string name="apt3_q1_a">बहुत अच्छा</string>
