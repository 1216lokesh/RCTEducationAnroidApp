    <string name="final_subtitle">கடைசி கேள்விகள்</string>
    <string name="final_q1">1. எவ்வளவு அடிக்கடி பல் மருத்துவரை சந்திக்க வேண்டும்?</string>
    <string name="final_q1_a">ஒவ்வொரு 6 மாதமும்</string>
    <string name="final_q1_b">வலிக்கும்போது மட்டும்</string>
    <string name="final_q1_c">வருடத்திற்கு ஒரு முறை</string>
    <string name="final_q2">2. கிரீடம் தளர்வாக உணர்ந்தால் என்ன செய்ய வேண்டும்?</string>
    <string name="final_q2_a">கவலைப்படாதே</string>
    <string name="final_q2_b">உடனே மருத்துவரை தொடர்பு கொள்ளவும்</string>
    <string name="final_q2_c">பல் பசை பயன்படுத்தவும்</string>
    <string name="final_q3">3. இந்த பயன்பாடு வேர் கால் சிகிச்சையைப் பற்றிய உங்கள் அறிவை மேம்படுத்தியதா?</string>
